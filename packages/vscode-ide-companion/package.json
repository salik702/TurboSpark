{
  "name": "turbospark-vscode-ide-companion",
  "displayName": "TURBO SPARK Companion",
  "description": "Enable TURBO SPARK with direct access to your VS Code workspace.",
  "version": "0.18.3",
  "publisher": "turbospark",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/turbospark/turbospark.git",
    "directory": "packages/vscode-ide-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "LICENSE",
  "preview": true,
  "categories": [
    "AI"
  ],
  "keywords": [
    "turbospark",
    "turbospark",
    "turbospark",
    "turbospark",
    "cli",
    "ide integration",
    "ide companion"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:turbospark.chatView.sidebar",
    "onView:turbospark.chatView.secondary",
    "onCommand:turbospark.openChat",
    "onCommand:turbospark.focusChat",
    "onCommand:turbospark.newConversation",
    "onCommand:turbospark.showLogs"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "**/.turbospark/settings.json",
        "url": "./schemas/settings.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "turbospark-sidebar",
          "title": "TURBO SPARK",
          "icon": "assets/sidebar-icon.svg",
          "when": "!turbospark:supportsSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "turbospark-secondary",
          "title": "TURBO SPARK",
          "icon": "assets/sidebar-icon.svg",
          "when": "turbospark:supportsSecondarySidebar"
        }
      ]
    },
    "views": {
      "turbospark-sidebar": [
        {
          "type": "webview",
          "id": "turbospark.chatView.sidebar",
          "name": "TURBO SPARK",
          "icon": "assets/sidebar-icon.svg",
          "when": "!turbospark:supportsSecondarySidebar"
        }
      ],
      "turbospark-secondary": [
        {
          "type": "webview",
          "id": "turbospark.chatView.secondary",
          "name": "TURBO SPARK",
          "icon": "assets/sidebar-icon.svg",
          "when": "turbospark:supportsSecondarySidebar"
        }
      ]
    },
    "languages": [
      {
        "id": "turbospark-diff-editable"
      }
    ],
    "commands": [
      {
        "command": "turbospark.diff.accept",
        "title": "TURBO SPARK: Accept Current Diff",
        "icon": "$(check)"
      },
      {
        "command": "turbospark.diff.cancel",
        "title": "TURBO SPARK: Close Diff Editor",
        "icon": "$(close)"
      },
      {
        "command": "turbospark.runTurbosparkCode",
        "title": "TURBO SPARK: Run"
      },
      {
        "command": "turbospark.showNotices",
        "title": "TURBO SPARK: View Third-Party Notices"
      },
      {
        "command": "turbospark.openChat",
        "title": "TURBO SPARK: Open",
        "icon": "./assets/icon.png"
      },
      {
        "command": "turbospark.auth",
        "title": "TURBO SPARK: Auth"
      },
      {
        "command": "turbospark.focusChat",
        "title": "TURBO SPARK: Focus Chat View"
      },
      {
        "command": "turbospark.newConversation",
        "title": "TURBO SPARK: New Conversation"
      },
      {
        "command": "turbospark.showLogs",
        "title": "TURBO SPARK: Show Logs"
      },
      {
        "command": "turbospark.copyMessage",
        "title": "%turbospark.copyMessage.title%"
      },
      {
        "command": "turbospark.copyAllMessages",
        "title": "%turbospark.copyAllMessages.title%"
      },
      {
        "command": "turbospark.copyLastReply",
        "title": "%turbospark.copyLastReply.title%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "turbospark.diff.accept",
          "when": "turbospark.diff.isVisible"
        },
        {
          "command": "turbospark.diff.cancel",
          "when": "turbospark.diff.isVisible"
        },
        {
          "command": "turbospark.auth"
        },
        {
          "command": "turbospark.copyMessage",
          "when": "false"
        },
        {
          "command": "turbospark.copyAllMessages",
          "when": "false"
        },
        {
          "command": "turbospark.copyLastReply",
          "when": "false"
        }
      ],
      "webview/context": [
        {
          "command": "turbospark.copyMessage",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@1"
        },
        {
          "command": "turbospark.copyAllMessages",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@2"
        },
        {
          "command": "turbospark.copyLastReply",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@3"
        }
      ],
      "editor/title": [
        {
          "command": "turbospark.diff.accept",
          "when": "turbospark.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "turbospark.diff.cancel",
          "when": "turbospark.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "turbospark.openChat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TURBO SPARK",
      "properties": {
        "turbospark.provider": {
          "order": 0,
          "type": "string",
          "enum": [
            "coding-plan",
            "api-key"
          ],
          "enumDescriptions": [
            "Alibaba Cloud Coding Plan — configurable from VS Code Settings",
            "Configured via TURBO SPARK: Auth or the onboarding button"
          ],
          "default": "coding-plan",
          "markdownDescription": "**Coding Plan**: enter API Key + Region here to sync `~/.turbospark/settings.json`.\n\n**API Key**: use **TURBO SPARK: Auth** or the onboarding button to configure ModelStudio or custom OpenAI-compatible providers."
        },
        "turbospark.apiKey": {
          "order": 1,
          "type": "string",
          "default": "",
          "markdownDescription": "API key used for **Coding Plan** settings sync. For **API Key** providers, configure the full provider details through **TURBO SPARK: Auth**."
        },
        "turbospark.codingPlanRegion": {
          "order": 2,
          "type": "string",
          "enum": [
            "china",
            "global"
          ],
          "enumDescriptions": [
            "China — 阿里云百炼 (aliyun.com)",
            "Global — Alibaba Cloud (alibabacloud.com)"
          ],
          "default": "china",
          "markdownDescription": "Region for Coding Plan. _(Only used when Provider is `coding-plan`)_"
        },
        "turbospark.dotIndicator": {
          "order": 3,
          "type": "boolean",
          "default": true,
          "description": "Show a colored dot on the tab icon when a task completes (orange) or needs your attention (blue) while the tab is hidden."
        },
        "turbospark.notifications": {
          "order": 4,
          "type": "boolean",
          "default": true,
          "description": "Show notifications with sound when a task completes (at least 20 seconds) or needs your attention, while you are not actively viewing the TURBO SPARK panel."
        }
      }
    },
    "keybindings": [
      {
        "command": "turbospark.diff.accept",
        "key": "ctrl+s",
        "when": "turbospark.diff.isVisible"
      },
      {
        "command": "turbospark.diff.accept",
        "key": "cmd+s",
        "when": "turbospark.diff.isVisible"
      },
      {
        "command": "turbospark.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
  "main": "./dist/extension.cjs",
  "type": "module",
  "scripts": {
    "prepackage": "node ./scripts/prepackage.js",
    "build": "npm run build:dev",
    "build:dev": "npm run check-types && npm run lint && node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "generate:notices": "node ./scripts/generate-notices.js",
    "prepare": "npm run generate:notices",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "watch": "npm-run-all2 -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "validate:notices": "node ./scripts/validate-notices.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/vsce": "^3.9.2",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "npm-run-all2": "^8.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@turbospark/sdk": "*",
    "@turbospark/webui": "*",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "cors": "^2.8.5",
    "dotenv": "^17.1.0",
    "express": "^5.1.0",
    "markdown-it": "^14.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.2",
    "zod": "^3.25.76"
  }
}
