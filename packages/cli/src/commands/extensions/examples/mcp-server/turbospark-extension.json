{
  "name": "mcp-server-example",
  "displayName": {
    "en": "MCP Server Example",
    "zh": "MCP 服务器示例"
  },
  "description": {
    "en": "Example extension that provides an MCP server",
    "zh": "提供 MCP 服务器的示例扩展"
  },
